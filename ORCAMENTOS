        function fecharCalculadora() {
            document.getElementById('modalCalculadora').classList.add('hidden');
            document.getElementById('modalCalculadora').classList.remove('flex');
        }
        function formatarExibicao(valor) {
            if (valor === 'Erro') return 'Erro';
            
            // Divide por operadores para formatar números individualmente
            let partes = valor.split(/([\+\-\*\/])/);
            return partes.map(parte => {
                if (/^[\d.]+$/.test(parte)) {
                    return parseFloat(parte).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                }
                return parte;
            }).join('');
        }
        function calc(val) {
            console.log('calc called with:', val, 'valorCalculo:', valorCalculo);
            const display = document.getElementById('displayCalculadora');
            
            if (val === 'C') {
                valorCalculo = '0';
            } else if (val === '=') {
                try {
                    let result = eval(valorCalculo);
                    valorCalculo = result.toString();
                } catch (e) {
                    valorCalculo = 'Erro';
                }
            } else if (val === 'Backspace') {
                valorCalculo = valorCalculo.slice(0, -1);
                if (valorCalculo === '') valorCalculo = '0';
            } else {
                if (valorCalculo === '0' && val !== '.') {
                    valorCalculo = val;
                } else {
                    valorCalculo += val;
                }
            }
            
            display.value = formatarExibicao(valorCalculo);
            console.log('calc finished, valorCalculo:', valorCalculo, 'display.value:', display.value);
        }

        document.addEventListener('keydown', function(e) {
            const modal = document.getElementById('modalCalculadora');
            if (modal.classList.contains('hidden')) return;

            const key = e.key;
            console.log('keydown:', key);
            if (/[0-9]/.test(key) || ['+', '-', '*', '/'].includes(key)) {
                e.preventDefault();
                calc(key);
            } else if (key === 'Enter') {
                e.preventDefault();
                calc('=');
            } else if (key === 'Escape') {
                e.preventDefault();
                const display = document.getElementById('displayCalculadora');
                if (display.value !== '0') {
                    calc('C');
                } else {
                    fecharCalculadora();
                }
            } else if (key === 'Backspace') {
                e.preventDefault();
                calc('Backspace');
            }
        });

