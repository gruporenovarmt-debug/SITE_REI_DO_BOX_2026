        function calcularTudo() {
            const tipo = document.getElementById('tipoBox').value;
            let totalBox = 0;
            let totalArea = 0;

            const isManutencao = tipo === "Manutenção em Box";
            const isEspelho = tipo === "Espelho Prata";

            if (isManutencao) {
                const valorManutencaoStr = document.getElementById('valorManutencao').value;
                totalBox = parseFloat(valorManutencaoStr.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
            } else if (isEspelho) {
                const h = parseFloat(document.getElementById('altura').value) || 0;
                const w1 = parseFloat(document.getElementById('largura').value) || 0;
                const m2Str = document.getElementById('valorM2').value;
                const m2 = parseFloat(m2Str.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
                
                totalArea = h * w1;
                totalBox = totalArea * m2;
            } else {
                const h = parseFloat(document.getElementById('altura').value) || 0;
                const w1 = parseFloat(document.getElementById('largura').value) || 0;
                let wTotal = w1;

                if (tipo === "Box de Canto (Tipo L)") {
                    const w2 = parseFloat(document.getElementById('largura2').value) || 0;
                    wTotal = w1 + w2;
                }

                const m2Str = document.getElementById('valorM2').value;
                const m2 = parseFloat(m2Str.replace(/[^\d,]/g, '').replace(',', '.')) || 0;

                totalArea = h * wTotal;
                
                // Regra de área mínima de 1.25m² para Box
                const areaParaCalculo = totalArea < 1.25 ? 1.25 : totalArea;
                totalBox = areaParaCalculo * m2;
            }
            
            let valorFinal = totalBox;
            
            document.getElementById('areaTotalCalculada').innerText = totalArea.toFixed(2) + " m²";
            document.getElementById('valorFinalCalculado').innerText = valorFinal.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            document.getElementById('lucroVenda').innerText = valorFinal.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            
            // Atualizar Nome e Serviço na aba Lucro
            const clienteRaw = document.getElementById('nomeCliente').value;
            document.getElementById('lucroNomeCliente').innerText = clienteRaw || "-";
            document.getElementById('lucroServico').innerText = tipo || "-";

            // Cálculos Administrativos
            const maoObraStr = document.getElementById('custoMaoDeObra').value;
            const materiaisStr = document.getElementById('custoMateriais').value;
            const maoObra = parseFloat(maoObraStr.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
            const materiais = parseFloat(materiaisStr.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
            
            let totalDespesasExtras = 0;
            const rowsExtras = document.querySelectorAll('.despesa-extra-row');
            rowsExtras.forEach(row => {
                const valInput = row.querySelectorAll('input')[1];
                const val = parseFloat(valInput.value.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
                totalDespesasExtras += val;
            });

            const lucro = totalBox - maoObra - materiais - totalDespesasExtras;
            const lucroEl = document.getElementById('lucroCalculado');
            const containerLucro = document.getElementById('containerLucroLiquido');
            const labelLucro = document.getElementById('labelLucroLiquido');
            const iconLucro = document.getElementById('iconLucroLiquido');

            lucroEl.innerText = lucro.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });

            if (lucro < 0) {
                containerLucro.classList.remove('bg-slate-900');
                containerLucro.classList.add('bg-red-600');
                labelLucro.innerText = "NESSE SERVIÇO VOCÊ ESTA EM PREJUIZO";
                iconLucro.innerText = "😞";
                lucroEl.classList.remove('text-green-400');
                lucroEl.classList.add('text-white');
            } else {
                containerLucro.classList.add('bg-slate-900');
                containerLucro.classList.remove('bg-red-600');
                labelLucro.innerText = "Lucro Líquido";
                iconLucro.innerText = "💰";
                lucroEl.classList.add('text-green-400');
                lucroEl.classList.remove('text-white');
            }

            verificarAlteracoesLucro();
            gerarTabela(totalBox);
            prepararExportacao(totalBox);
            prepararExportacaoAdmin(totalBox, maoObra, materiais, lucro);
        }

