                    </div>
                    <div class="flex items-center gap-1">
                        <button onclick="ativarEdicaoConta(this)" class="text-slate-400 hover:text-slate-600 p-1 transition-all active:scale-90 shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                            </svg>
                        </button>
                        <button onclick="salvarContas(this)" class="btn-salvar-row hidden bg-slate-900 text-white px-3 py-1 rounded-lg font-black text-[9px] uppercase tracking-widest hover:bg-black transition-all active:scale-95 flex items-center gap-1 shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                            </svg>
                            SALVAR
                        </button>
                        <button onclick="removerConta(this)" class="text-red-500 hover:text-red-700 p-1 transition-all active:scale-90 shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                        <input type="text" value="${valor}" placeholder="R$ 0,00" inputmode="numeric" 
                            oninput="mascaraMoeda(this); calcularContas()" 
                            onkeydown="checkMoedaPrefix(event)" 
                            onclick="fixMoedaCursor(this)"
                            onselect="fixMoedaCursor(this)"
                            onfocus="selecionarTudo(this)"
                            class="w-28 text-right bg-slate-50 border border-slate-200 rounded-lg py-1 px-2 text-sm font-black text-black outline-none focus:ring-2 focus:ring-amber-500/20 transition-all">
                    </div>
                </div>
                <div class="flex flex-wrap items-center gap-3 border-t border-slate-50 pt-2">
                    <div class="flex flex-col gap-0.5">
                        <label class="text-[9px] font-black text-slate-400 uppercase leading-none">Publicada</label>
                        <input type="date" value="${dataPublicada}" class="bg-transparent border-none p-0 text-[10px] font-bold text-slate-600 outline-none focus:ring-0">
                    </div>
                    <div class="flex flex-col gap-0.5">
                        <label class="text-[9px] font-black text-slate-400 uppercase leading-none">Vencimento</label>
                        <input type="date" value="${dataVencimento}" onchange="atualizarStatusVisual(this.closest('.conta-row'))" class="bg-transparent border-none p-0 text-[10px] font-bold text-slate-600 outline-none focus:ring-0">
                    </div>
                    ${tipo === 'fixa' ? `
                    <div class="flex items-center gap-1.5 ml-auto">
