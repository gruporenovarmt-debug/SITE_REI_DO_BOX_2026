    <script>
        let orcamentoEditandoId = null;
        let orcamentoOriginalData = null;
        let idParaExcluir = null;
        let whatsappTexto = "";
        let paginaAtualHistorico = 1;
        let desconto = 0;
        let tipoDesconto = 'RS';
        const itensPorPagina = 10;
        const taxas = {
            1: 4.2, 2: 6.09, 3: 7.01, 4: 7.91, 5: 8.80, 6: 9.67, 
            7: 12.59, 8: 13.42, 9: 14.25, 10: 15.06, 11: 15.87, 12: 16.66
        };

        function mascaraMoeda(i) {
            let v = i.value.replace(/\D/g, '');
            v = (v / 100).toFixed(2) + '';
            v = v.replace(".", ",");
            v = v.replace(/(\d)(?=(\d{3})+(?!\d))/g, "$1.");
            i.value = v ? 'R$ ' + v : '';
            calcularTudo();
        }

        function switchTab(tab) {
            playSound('click');
            const tabs = [
                { id: 'orcamento', btn: document.getElementById('tabOrcamento'), content: document.getElementById('contentOrcamento') },
                { id: 'lucro', btn: document.getElementById('tabLucro'), content: document.getElementById('contentLucro') },
                { id: 'historico', btn: document.getElementById('tabHistorico'), content: document.getElementById('contentHistorico') },
                { id: 'notificacoes', btn: document.getElementById('tabNotificacoes'), content: document.getElementById('contentNotificacoes') },
                { id: 'contas', btn: document.getElementById('tabContas'), content: document.getElementById('contentContas') }
            ];
            const containerPreview = document.getElementById('containerPreview');

            tabs.forEach(t => {
                if (t.id === tab) {
                    // Ativar aba
                    t.btn.classList.remove('tab-inactive');
                    t.btn.classList.add('tab-active');
                    t.content.classList.remove('hidden');
                    t.content.classList.add('tab-content-active');
                    
                    if (tab === 'notificacoes') carregarNotificacoes();
                    if (tab === 'contas') carregarContas();
                } else {
                    // Desativar aba
                    t.btn.classList.remove('tab-active');
                    t.btn.classList.add('tab-inactive');
                    t.content.classList.add('hidden');
                    t.content.classList.remove('tab-content-active');
                }
            });

            // Atualiza estado do botão de despesas extras
            const btnExtra = document.querySelector('button[onclick="adicionarDespesaExtra()"]');
            if (btnExtra) {
                if (!orcamentoEditandoId) {
                    btnExtra.classList.add('opacity-50', 'cursor-not-allowed');
                } else {
                    btnExtra.classList.remove('opacity-50', 'cursor-not-allowed');
                }
            }

            // Atualizar visibilidade do botão de notificação
            verificarNotificacoes();

            // Lógica específica para o preview do Orçamento
            if (tab === 'orcamento') {
                calcularTudo();
            } else {
                containerPreview.classList.add('hidden');
                if (tab === 'lucro' || tab === 'historico') {
                    carregarHistorico();
                }
            }
        }

        function mascaraMedida(i) {
            let v = i.value.replace(/\D/g, '');
            v = (v / 100).toFixed(2);
            i.value = v;
            calcularTudo();
        }

        function mascaraNome(i) {
            // Bloqueia números e força caixa alta
            let v = i.value.replace(/[0-9]/g, '');
            i.value = v.toUpperCase();
            calcularTudo();
        }

        function mascaraMaiuscula(i) {
            i.value = i.value.toUpperCase();
        }

        function checkMoedaPrefix(e) {
            const input = e.target;
            // Impede apagar o prefixo R$ 
            if (input.selectionStart < 3 && (e.key === 'Backspace' || e.key === 'Delete')) {
                e.preventDefault();
            }
        }

        function fixMoedaCursor(input) {
            if (input.selectionStart < 3) {
                if (input.selectionEnd > 3) {
                    input.setSelectionRange(3, input.selectionEnd);
                } else {
                    input.setSelectionRange(3, 3);
                }
            }
        }

        function selecionarTudo(input) {
            setTimeout(() => {
                input.select();
            }, 10);
        }

        const audioCache = {
            money: new Audio('https://cdn.pixabay.com/audio/2022/03/10/audio_c3502c2d8a.mp3'),
            success: new Audio('https://cdn.pixabay.com/audio/2021/08/04/audio_0625c1539c.mp3'),
            error: new Audio('https://cdn.pixabay.com/audio/2022/03/10/audio_783ed3a0e0.mp3'),
            click: new Audio('https://cdn.pixabay.com/audio/2022/03/15/audio_5072732c05.mp3')
        };

        function playSound(type) {
            const audio = audioCache[type];
            if (audio) {
                audio.currentTime = 0;
                audio.volume = 0.5;
                audio.play().catch(e => console.log("Audio play blocked by browser: " + e));
            }
        }

        function adicionarDespesaExtra(nome = "", valor = "R$ 0,00", silent = false) {
