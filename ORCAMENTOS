        function atualizarResumo(historico) {
            let totalGeralValor = 0;
            let totalGeralQtd = historico.length;

            let emAndamentoValor = 0;
            let emAndamentoQtd = 0;

            let vendasFechadasValor = 0;
            let vendasFechadasQtd = 0;

            let totalPerdidoValor = 0;
            let totalPerdidoQtd = 0;

            let totalLucroBruto = 0;

            historico.forEach(orc => {
                // Extração robusta do valor numérico da string de moeda (ex: "R$ 1.234,56" -> 1234.56)
                const valorLimpo = orc.valorTotal.replace(/[^\d,]/g, '').replace(',', '.');
                const valor = parseFloat(valorLimpo) || 0;
                
                totalGeralValor += valor;

                const status = orc.status || '1-Proposta Enviada';
                if (status === "1-Proposta Enviada" || status === "2-Pediu Retorno") {
                    emAndamentoValor += valor;
                    emAndamentoQtd++;
                } else if (status === "3-Venda Concluída") {
                    vendasFechadasValor += valor;
                    vendasFechadasQtd++;

                    // Cálculo do Lucro Bruto (Venda - Mão de Obra - Materiais)
                    const maoObra = parseFloat(orc.custoMaoDeObra?.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
                    const materiais = parseFloat(orc.custoMateriais?.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
                    totalLucroBruto += (valor - maoObra - materiais);
                } else if (status === "4-Desistiu") {
                    totalPerdidoValor += valor;
                    totalPerdidoQtd++;
                }
            });

            const formatMoeda = (v) => v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });

            document.getElementById('resumoTotalGeral').innerText = `${totalGeralQtd} - ${formatMoeda(totalGeralValor)}`;
            document.getElementById('resumoEmAndamento').innerText = `${emAndamentoQtd} - ${formatMoeda(emAndamentoValor)}`;
            document.getElementById('resumoVendasFechadas').innerText = `${vendasFechadasQtd} - ${formatMoeda(vendasFechadasValor)}`;
            document.getElementById('resumoTotalPerdido').innerText = `${totalPerdidoQtd} - ${formatMoeda(totalPerdidoValor)}`;
            document.getElementById('resumoLucroBruto').innerText = formatMoeda(totalLucroBruto);
            
            // Armazenar o lucro bruto total para uso no relatório
            window.totalLucroBrutoCalculado = formatMoeda(totalLucroBruto);
        }

