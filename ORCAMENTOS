            playSound('error');
            idParaExcluir = id;
            document.getElementById('modalConfirmacao').classList.remove('hidden');
            
            document.getElementById('btnConfirmarExclusao').onclick = function() {
                let historico = JSON.parse(localStorage.getItem('historico_orcamentos') || '[]');
                historico = historico.filter(o => o.id !== idParaExcluir);
                localStorage.setItem('historico_orcamentos', JSON.stringify(historico));
                
