                const activeClass = i === paginaAtualHistorico ? 'bg-slate-900 text-white' : 'bg-white text-black border border-slate-200 hover:bg-slate-50';
                html += `<button onclick="mudarPagina(${i})" class="w-8 h-8 rounded-lg text-xs font-black transition-all ${activeClass}">${i}</button>`;
