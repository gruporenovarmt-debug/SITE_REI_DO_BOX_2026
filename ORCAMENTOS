        // --- Funções Minhas Contas ---
        function carregarContas() {
            const contas = JSON.parse(localStorage.getItem('minhas_contas') || '{"fixas":[], "variaveis":[]}');
            
            const containerFixas = document.getElementById('containerFixas');
            const containerVariaveis = document.getElementById('containerVariaveis');
            
            containerFixas.innerHTML = "";
            containerVariaveis.innerHTML = "";
            
            if (contas.fixas.length === 0) {
                containerFixas.innerHTML = '<div class="p-4 text-center text-slate-400 font-bold text-[10px] uppercase border-2 border-dashed border-slate-100 rounded-xl">Nenhuma despesa fixa</div>';
            } else {
                // Inverter para manter ordem decrescente ao renderizar com prepend
                [...contas.fixas].reverse().forEach(c => renderizarLinhaConta('fixa', c.nome, c.valor, c.dataPublicada, c.dataVencimento, c.alertar, c.status));
            }
            
            if (contas.variaveis.length === 0) {
                containerVariaveis.innerHTML = '<div class="p-4 text-center text-slate-400 font-bold text-[10px] uppercase border-2 border-dashed border-slate-100 rounded-xl">Nenhuma despesa variável</div>';
            } else {
                // Inverter para manter ordem decrescente ao renderizar com prepend
                [...contas.variaveis].reverse().forEach(c => renderizarLinhaConta('variavel', c.nome, c.valor, c.dataPublicada, c.dataVencimento, c.alertar, c.status));
            }
            
            calcularContas();
        }

        function renderizarLinhaConta(tipo, nome = "", valor = "R$ 0,00", dataPublicada = "", dataVencimento = "", alertar = false, status = "pendente") {
