        function copiarWhatsApp() {
            const cliente = document.getElementById('nomeCliente').value;
            const h = document.getElementById('altura').value;
            const w1 = document.getElementById('largura').value;
            const w2 = document.getElementById('largura2').value;
            const total = document.getElementById('valorFinalCalculado').innerText;
            const tipo = document.getElementById('tipoBox').value;
            const valorM2 = document.getElementById('valorM2').value;
            const valorManutencao = document.getElementById('valorManutencao').value;

            const isManutencao = tipo === "Manutenção em Box";
            const isCanto = tipo === "Box de Canto (Tipo L)";

            let invalidFields = [];

            // Validação rigorosa
            if (!cliente || cliente.length < 3) invalidFields.push('nomeCliente');
            if (total === "R$ 0,00") {
                if (isManutencao) invalidFields.push('valorManutencao');
                else invalidFields.push('valorM2');
            }

            // Validação específica para m² ou Manutenção
            if (!isManutencao && (valorM2 === "R$ 0,00" || valorM2 === "")) invalidFields.push('valorM2');
            if (isManutencao && (valorManutencao === "R$ 0,00" || valorManutencao === "")) invalidFields.push('valorManutencao');

            if (!isManutencao) {
                if (h === "0.00") invalidFields.push('altura');
                if (w1 === "0.00") invalidFields.push('largura');
            }

            if (isCanto && w2 === "0.00") invalidFields.push('largura2');

            if (invalidFields.length > 0) {
                highlightInvalidFields(invalidFields);
                playSound('error');
                showPopup("Preencha tudo corretamente");
                return;
            }

            const texto = whatsappTexto || document.getElementById('whatsappPreview').innerText || document.getElementById('whatsappPreview').textContent;

            // Fallback para cópia em ambientes restritos
            function fallbackCopyTextToClipboard(text) {
                const textArea = document.createElement("textarea");
                textArea.value = text;
                textArea.style.position = "fixed";
                textArea.style.left = "-9999px";
                textArea.style.top = "0";
                document.body.appendChild(textArea);
                textArea.focus();
                textArea.select();
                try {
                    const successful = document.execCommand('copy');
                    if (successful) {
                        playSound('success');
                        showPopup("Pronto! Sua oferta esta salva, e copiada.");
                    } else {
                        playSound('error');
                        showPopup("Não foi possível copiar automaticamente. Por favor, selecione o texto manualmente.");
                    }
                } catch (err) {
                    console.error('Fallback: Erro ao copiar', err);
                    playSound('error');
                    showPopup("Erro ao copiar a oferta. Por favor, tente novamente.");
                }
                document.body.removeChild(textArea);
            }

            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(texto).then(() => {
                    playSound('success');
                    showPopup("Pronto! Sua oferta esta salva, e copiada.");
                }).catch((err) => {
                    console.error('Async: Erro ao copiar', err);
                    fallbackCopyTextToClipboard(texto);
                });
            } else {
                fallbackCopyTextToClipboard(texto);
            }
        }

