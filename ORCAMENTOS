            const filtroOrigem = document.getElementById('filtroOrigem')?.value || 'TODOS';
            const filtroNome = document.getElementById('filtroNome')?.value.toUpperCase() || '';
            let historico = JSON.parse(localStorage.getItem('historico_orcamentos') || '[]');
            
            if (historico.length === 0) {
                const emptyMsg = `<div class="p-8 text-center text-black font-padrao text-xs uppercase font-bold">Nenhum orçamento salvo ainda.</div>`;
                if (lista) lista.innerHTML = emptyMsg;
                if (listaLucro) listaLucro.innerHTML = emptyMsg;
                atualizarResumo(historico);
                return;
            }

            atualizarResumo(historico);

            // Aplicar filtros
            let historicoFiltrado = [...historico];
            if (filtro !== 'TODOS') {
                historicoFiltrado = historicoFiltrado.filter(orc => (orc.status || '1-Proposta Enviada') === filtro);
            }
            if (filtroOrigem !== 'TODOS') {
                historicoFiltrado = historicoFiltrado.filter(orc => orc.origemCliente === filtroOrigem);
