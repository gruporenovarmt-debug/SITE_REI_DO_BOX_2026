        function ativarEdicaoConta(btn) {
            playSound('click');
            const row = btn.closest('.conta-row');
            const inputNome = row.querySelector('input[type="text"]');
            const btnSalvar = row.querySelector('.btn-salvar-row');
            
            inputNome.focus();
            inputNome.select();
            btnSalvar.classList.remove('hidden');
            
            // Também exibe os botões de salvar globais
            document.querySelectorAll('.btn-salvar-contas-global').forEach(b => b.classList.remove('hidden'));
        }

        function getStatusInfo(status, dataVencimento, dataPublicada) {
            if (status === 'paga') return { label: 'Paga', color: 'bg-emerald-100 text-emerald-700 border-emerald-200', boxColor: 'bg-emerald-50 border-emerald-100' };
            if (!dataVencimento) return { label: 'Pendente', color: 'bg-slate-100 text-slate-700 border-slate-200', boxColor: 'bg-white border-slate-100' };
            
            const hoje = new Date().toISOString().split('T')[0];
            const dataH = new Date();
            dataH.setDate(dataH.getDate() + 1);
            const amanha = dataH.toISOString().split('T')[0];

            if (dataVencimento < hoje) return { label: 'Vencida', color: 'bg-red-100 text-red-700 border-red-200', boxColor: 'bg-red-50 border-red-100' };
            if (dataVencimento === hoje || dataVencimento === amanha) return { label: dataVencimento === hoje ? 'Vence Hoje' : 'Vence Amanhã', color: 'bg-amber-100 text-amber-700 border-amber-200', boxColor: 'bg-amber-50 border-amber-100' };
            if (dataPublicada === hoje) return { label: 'Lançada Recente', color: 'bg-blue-100 text-blue-700 border-blue-200', boxColor: 'bg-blue-50 border-blue-100' };
            
            return { label: 'A Vencer', color: 'bg-slate-100 text-slate-700 border-slate-200', boxColor: 'bg-white border-slate-100' };
        }

        function atualizarStatusVisual(row) {
            const statusBadge = row.querySelector('.status-badge');
            const status = statusBadge.innerText.trim().toLowerCase() === 'paga' ? 'paga' : 'pendente';
            const dataVencimento = row.querySelector('input[type="date"]:nth-of-type(2)')?.value || 
                                  row.querySelectorAll('input[type="date"]')[1]?.value;
            const dataPublicada = row.querySelector('input[type="date"]:nth-of-type(1)')?.value || 
                                   row.querySelectorAll('input[type="date"]')[0]?.value;
            
            const info = getStatusInfo(status, dataVencimento, dataPublicada);
            statusBadge.innerText = info.label;
            statusBadge.className = `status-badge px-2 py-0.5 rounded-full text-[9px] font-black uppercase tracking-widest transition-all border ${info.color}`;
            
            // Atualiza a cor do box
            row.className = `flex flex-col gap-2 p-3 rounded-xl border shadow-sm transition-all conta-row ${info.boxColor}`;
        }

        function toggleStatusConta(btn) {
            playSound('click');
            const isPaga = btn.innerText.trim().toUpperCase() === 'PAGA';
            const row = btn.closest('.conta-row');
            const dataVencimento = row.querySelectorAll('input[type="date"]')[1].value;
            
            if (isPaga) {
                // Mudar para pendente (recalcula cor baseada na data)
                const info = getStatusInfo('pendente', dataVencimento);
                btn.innerText = info.label;
                btn.className = `status-badge px-2 py-0.5 rounded-full text-[9px] font-black uppercase tracking-widest transition-all border ${info.color}`;
            } else {
                // Mudar para paga
                btn.innerText = 'Paga';
                btn.className = 'status-badge px-2 py-0.5 rounded-full text-[9px] font-black uppercase tracking-widest transition-all border bg-emerald-100 text-emerald-700 border-emerald-200';
            }
        }

        function adicionarConta(tipo) {
            playSound('click');
            
            // Validação: Não permite adicionar se houver uma conta sem nome ou com o nome padrão
            const container = tipo === 'fixa' ? document.getElementById('containerFixas') : document.getElementById('containerVariaveis');
            const rows = container.querySelectorAll('.conta-row');
            let hasEmpty = false;
            
            rows.forEach(row => {
                const nome = row.querySelector('input[type="text"]').value.trim();
                if (!nome || nome === "NOME DA SUA CONTA") {
                    hasEmpty = true;
                    row.classList.add('animate-shake', 'border-red-500');
                    setTimeout(() => row.classList.remove('animate-shake', 'border-red-500'), 1000);
                }
            });
            
            if (hasEmpty) {
                playSound('error');
                showAdicionarFeedback(tipo, "PREENCHA A DESPESA COM UM NOME");
                return;
            }

            renderizarLinhaConta(tipo, "NOME DA SUA CONTA");
            calcularContas();
            
            // Ativa edição na primeira linha adicionada (prepend)
            const firstRow = container.firstElementChild;
            if (firstRow) {
                const btnEdit = firstRow.querySelector('button[onclick="ativarEdicaoConta(this)"]');
                if (btnEdit) ativarEdicaoConta(btnEdit);
            }

            // Exibe os botões de salvar globais
            document.querySelectorAll('.btn-salvar-contas-global').forEach(btn => btn.classList.remove('hidden'));
        }

        function removerConta(btn) {
            playSound('error');
            const row = btn.closest('.conta-row');
            const container = row.parentElement;
            row.remove();
            
            if (container.children.length === 0) {
                const tipo = container.id === 'containerFixas' ? 'fixa' : 'variável';
                container.innerHTML = `<div class="p-4 text-center text-slate-400 font-bold text-[10px] uppercase border-2 border-dashed border-slate-100 rounded-xl">Nenhuma despesa ${tipo}</div>`;
            }
            
            calcularContas();
        }

        function calcularContas() {
            let totalFixas = 0;
            let totalVariaveis = 0;
            let countFixas = 0;
            let countVariaveis = 0;
            
            document.querySelectorAll('#containerFixas .conta-row').forEach(row => {
                const valStr = row.querySelector('input[inputmode="numeric"]').value;
                totalFixas += parseFloat(valStr.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
                countFixas++;
            });
            
            document.querySelectorAll('#containerVariaveis .conta-row').forEach(row => {
                const valStr = row.querySelector('input[inputmode="numeric"]').value;
                totalVariaveis += parseFloat(valStr.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
                countVariaveis++;
            });
            
            const totalGeral = totalFixas + totalVariaveis;
            
            document.getElementById('totalFixas').innerText = totalFixas.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            document.getElementById('totalVariaveis').innerText = totalVariaveis.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            document.getElementById('totalGeralContas').innerText = totalGeral.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });

            // Atualizar contadores
            document.getElementById('countFixas').innerText = countFixas;
            document.getElementById('countVariaveis').innerText = countVariaveis;

            // Bloquear botão de salvar se não houver itens
            const totalItens = countFixas + countVariaveis;
            document.querySelectorAll('.btn-salvar-contas-global').forEach(btn => {
                btn.disabled = totalItens === 0;
            });
        }

        function salvarContas(btnElement = null) {
            playSound('click');
            const fixas = [];
            const variaveis = [];
            let hasError = false;
            let errorMsg = "DÊ UM NOME A SUA CONTA";
            const hoje = new Date().toISOString().split('T')[0];
            
            document.querySelectorAll('#containerFixas .conta-row').forEach(row => {
                const inputs = row.querySelectorAll('input');
                const nome = inputs[0].value.trim();
                const valor = inputs[1].value;
                const dataPublicada = inputs[2].value;
                const dataVencimento = inputs[3].value;
                const alertar = inputs[4] ? inputs[4].checked : false;
                const statusText = row.querySelector('.status-badge').innerText.trim().toLowerCase();
                const status = statusText === 'paga' ? 'paga' : 'pendente';

                if (nome === "NOME DA SUA CONTA" || !nome) {
                    hasError = true;
                    showAdicionarFeedback('fixa', errorMsg);
                    row.classList.add('animate-shake', 'border-red-500');
                    setTimeout(() => row.classList.remove('animate-shake', 'border-red-500'), 1000);
                } else if (dataPublicada > hoje) {
                    hasError = true;
                    showAdicionarFeedback('fixa', "DATA DE LANÇAMENTO INVÁLIDA");
                    inputs[2].classList.add('text-red-500', 'animate-shake');
                    setTimeout(() => inputs[2].classList.remove('text-red-500', 'animate-shake'), 2000);
                } else if (dataVencimento && dataVencimento < dataPublicada) {
                    hasError = true;
                    showAdicionarFeedback('fixa', "VENCIMENTO INVÁLIDO");
                    inputs[3].classList.add('text-red-500', 'animate-shake');
                    setTimeout(() => inputs[3].classList.remove('text-red-500', 'animate-shake'), 2000);
                } else if (nome || valor !== "R$ 0,00") {
                    fixas.push({ nome, valor, dataPublicada, dataVencimento, alertar, status });
                }
            });
            
            document.querySelectorAll('#containerVariaveis .conta-row').forEach(row => {
                const inputs = row.querySelectorAll('input');
                const nome = inputs[0].value.trim();
                const valor = inputs[1].value;
                const dataPublicada = inputs[2].value;
                const dataVencimento = inputs[3].value;
                const statusText = row.querySelector('.status-badge').innerText.trim().toLowerCase();
                const status = statusText === 'paga' ? 'paga' : 'pendente';

                if (nome === "NOME DA SUA CONTA" || !nome) {
                    hasError = true;
                    showAdicionarFeedback('variavel', errorMsg);
                    row.classList.add('animate-shake', 'border-red-500');
                    setTimeout(() => row.classList.remove('animate-shake', 'border-red-500'), 1000);
                } else if (dataPublicada > hoje) {
                    hasError = true;
                    showAdicionarFeedback('variavel', "DATA DE LANÇAMENTO INVÁLIDA");
                    inputs[2].classList.add('text-red-500', 'animate-shake');
                    setTimeout(() => inputs[2].classList.remove('text-red-500', 'animate-shake'), 2000);
                } else if (dataVencimento && dataVencimento < dataPublicada) {
                    hasError = true;
                    showAdicionarFeedback('variavel', "VENCIMENTO INVÁLIDO");
                    inputs[3].classList.add('text-red-500', 'animate-shake');
                    setTimeout(() => inputs[3].classList.remove('text-red-500', 'animate-shake'), 2000);
                } else if (nome || valor !== "R$ 0,00") {
                    variaveis.push({ nome, valor, dataPublicada, dataVencimento, status });
                }
            });

            if (hasError) {
                playSound('error');
                return;
            }

            if (fixas.length === 0 && variaveis.length === 0) {
                if (btnElement) {
                    const btnContent = btnElement.querySelector('.btn-content') || document.getElementById('btnSalvarContasContent');
                    showButtonFeedback(btnElement.id || btnElement, btnContent, "Nenhuma despesa", "error", 'bg-slate-900', 'hover:bg-black');
                } else {
                    showButtonContasFeedback("Nem uma despesa cadastrada.", "error");
                }
                playSound('error');
                return;
            }
            
            localStorage.setItem('minhas_contas', JSON.stringify({ fixas, variaveis }));
            playSound('success');
            
            if (btnElement) {
                const btnContent = btnElement.querySelector('.btn-content') || document.getElementById('btnSalvarContasContent');
                showButtonFeedback(btnElement.id || btnElement, btnContent, "TUDO SALVO", "success", 'bg-slate-900', 'hover:bg-black', 1000);
            } else {
                showButtonContasFeedback("TUDO SALVO", "success");
            }

            // Ocultar botões de salvar após o feedback
            setTimeout(() => {
                document.querySelectorAll('.btn-salvar-contas-global').forEach(btn => btn.classList.add('hidden'));
                document.querySelectorAll('.btn-salvar-row').forEach(btn => btn.classList.add('hidden'));
            }, 1000);
        }

        function gerarRelatorioContas(periodo) {
            playSound('click');
            const contas = JSON.parse(localStorage.getItem('minhas_contas') || '{"fixas":[], "variaveis":[]}');
            
            if (contas.fixas.length === 0 && contas.variaveis.length === 0) {
                showPopup("Nenhuma despesa para gerar relatório.");
                return;
            }

            let relatorio = `*RELATÓRIO DE DESPESAS (${periodo.toUpperCase()})*\n`;
            relatorio += `----------------------------------\n\n`;

            let totalGeral = 0;

            if (contas.fixas.length > 0) {
                relatorio += `*DESPESAS FIXAS:*\n`;
                contas.fixas.forEach(c => {
                    const valor = parseFloat(c.valor.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
                    totalGeral += valor;
                    relatorio += `• ${c.nome}: ${c.valor} (${c.status.toUpperCase()})\n`;
                });
                relatorio += `\n`;
            }

            if (contas.variaveis.length > 0) {
                relatorio += `*DESPESAS VARIÁVEIS:*\n`;
                contas.variaveis.forEach(c => {
                    const valor = parseFloat(c.valor.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
                    totalGeral += valor;
                    relatorio += `• ${c.nome}: ${c.valor} (${c.status.toUpperCase()})\n`;
                });
                relatorio += `\n`;
            }

            relatorio += `----------------------------------\n`;
            relatorio += `*TOTAL GERAL: ${totalGeral.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}*\n`;

            // Copiar para o clipboard
            const el = document.createElement('textarea');
            el.value = relatorio;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);

            showPopup(`Relatório ${periodo} copiado para a área de transferência!`);
        }

        // Inicializar estado
        novoOrcamento(true);
        verificarNotificacoes();
        carregarHistorico();
    </script>
    <div id="modalCalculadora" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
        <div class="bg-white p-4 rounded-2xl shadow-xl w-80">
            <div class="flex justify-between items-center mb-4">
                <h2 class="font-bold text-lg">Calculadora</h2>
                <button onclick="fecharCalculadora()" class="text-slate-500 hover:text-black">X</button>
            </div>
            <input type="text" id="displayCalculadora" class="w-full bg-slate-100 p-3 rounded-xl text-right text-2xl font-mono mb-4" readonly>
            <div class="grid grid-cols-4 gap-2">
                <button onclick="calc('7')" class="bg-slate-200 p-3 rounded-lg">7</button>
                <button onclick="calc('8')" class="bg-slate-200 p-3 rounded-lg">8</button>
                <button onclick="calc('9')" class="bg-slate-200 p-3 rounded-lg">9</button>
                <button onclick="calc('/')" class="bg-amber-500 text-white p-3 rounded-lg">/</button>
                <button onclick="calc('4')" class="bg-slate-200 p-3 rounded-lg">4</button>
                <button onclick="calc('5')" class="bg-slate-200 p-3 rounded-lg">5</button>
                <button onclick="calc('6')" class="bg-slate-200 p-3 rounded-lg">6</button>
                <button onclick="calc('*')" class="bg-amber-500 text-white p-3 rounded-lg">*</button>
                <button onclick="calc('1')" class="bg-slate-200 p-3 rounded-lg">1</button>
                <button onclick="calc('2')" class="bg-slate-200 p-3 rounded-lg">2</button>
                <button onclick="calc('3')" class="bg-slate-200 p-3 rounded-lg">3</button>
                <button onclick="calc('-')" class="bg-amber-500 text-white p-3 rounded-lg">-</button>
                <button onclick="calc('0')" class="bg-slate-200 p-3 rounded-lg">0</button>
                <button onclick="calc('.')" class="bg-slate-200 p-3 rounded-lg">.</button>
                <button onclick="calc('=')" class="bg-green-600 text-white p-3 rounded-lg">=</button>
                <button onclick="calc('+')" class="bg-amber-500 text-white p-3 rounded-lg">+</button>
                <button onclick="calc('C')" class="bg-red-500 text-white p-3 rounded-lg col-span-4">Limpar</button>
            </div>
        </div>
    </div>
