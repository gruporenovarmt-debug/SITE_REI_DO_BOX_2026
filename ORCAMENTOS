        function abrirOrcamento(id, tab = 'orcamento') {
            playSound('click');
            const historico = JSON.parse(localStorage.getItem('historico_orcamentos') || '[]');
            const orc = historico.find(o => o.id === id);
            if (!orc) return;

            orcamentoEditandoId = id; // Define o ID que está sendo editado

            document.getElementById('nomeCliente').value = orc.nomeCliente;
            if (orc.origemCliente) document.getElementById('origemCliente').value = orc.origemCliente;
            document.getElementById('tipoBox').value = orc.tipoBox;
            if (orc.tipoVidro) document.getElementById('tipoVidro').value = orc.tipoVidro;
            document.getElementById('acabamento').value = orc.acabamento;
            document.getElementById('altura').value = orc.altura;
            document.getElementById('largura').value = orc.largura;
            document.getElementById('largura2').value = orc.largura2;
            document.getElementById('valorM2').value = orc.valorM2;
            document.getElementById('valorManutencao').value = orc.valorManutencao;
            document.getElementById('observacao').value = orc.observacao || "";
            document.getElementById('custoMaoDeObra').value = orc.custoMaoDeObra || "R$ 0,00";
            document.getElementById('custoMateriais').value = orc.custoMateriais || "R$ 0,00";

            // Armazenar dados originais para detectar alterações
            orcamentoOriginalData = {
                custoMaoDeObra: orc.custoMaoDeObra || "R$ 0,00",
                custoMateriais: orc.custoMateriais || "R$ 0,00",
                despesasExtras: JSON.stringify(orc.despesasExtras || [])
            };

            // Limpar e carregar despesas extras
            document.getElementById('containerDespesasExtras').innerHTML = "";
            if (orc.despesasExtras && Array.from(orc.despesasExtras).length > 0) {
                orc.despesasExtras.forEach(dex => {
                    adicionarDespesaExtra(dex.nome, dex.valor, true);
                });
            }

            // Atualiza os campos de lucro na aba Lucro ADM
            document.getElementById('lucroNomeCliente').innerText = orc.nomeCliente;
            document.getElementById('lucroServico').innerText = orc.tipoBox;
            document.getElementById('lucroVenda').innerText = orc.valorTotal;

            document.getElementById('semParcelamento').checked = false;
            toggleLargura2(); // Atualiza visibilidade de campos
            calcularTudo(); // Recalcula os valores e atualiza o preview
            switchTab(tab);
            
            // Scroll para o topo
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

