<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Rei do Box - Simulador</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
    <style>
        body { background: #f1f5f9; font-family: 'Roboto', sans-serif; }
        .font-padrao { font-size: 14px !important; }
        .font-numeric { font-variant-numeric: tabular-nums; }
        .row-alt:nth-child(even) { background: #f8fafc; }
        input::placeholder { color: #cbd5e1; font-size: 12px; }
        
        /* Animação de transição das abas */
        .tab-content-active {
            display: block !important;
            animation: tabFadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        @keyframes tabFadeIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Efeito de destaque na aba ativa */
        .tab-active {
            background-color: #f59e0b !important; /* amber-500 */
            color: white !important;
            transform: scale(1.05);
            z-index: 10;
            box-shadow: 0 10px 15px -3px rgba(245, 158, 11, 0.3), 0 4px 6px -2px rgba(245, 158, 11, 0.1) !important;
        }
        
        .tab-inactive {
            color: #000000 !important; /* black */
        }
        
        .tab-inactive:hover {
            background-color: #f8fafc !important; /* slate-50 */
            color: #000000 !important; /* black */
        }

        .hover-row:hover {
            background-color: #e2e8f0 !important; /* slate-200 */
        }
        
        /* Estilo para o card de exportação (escondido da tela) */
        #exportCard {
            position: absolute;
            left: -9999px;
            top: 0;
            width: 550px;
            background: white;
            padding: 40px;
            border-radius: 0; /* Melhor para imagem */
        }

        @keyframes blink {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.4; transform: scale(1.1); }
            100% { opacity: 1; transform: scale(1); }
        }
        .animate-blink {
            animation: blink 1.5s infinite;
            box-shadow: 0 0 15px rgba(239, 68, 68, 0.5);
            border-color: #ef4444 !important;
            background-color: #fee2e2;
        }
        @keyframes bounce-in {
            0% { transform: scale(0.5); opacity: 0; }
            70% { transform: scale(1.05); opacity: 1; }
            100% { transform: scale(1); opacity: 1; }
        }
        .animate-bounce-in {
            animation: bounce-in 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            50% { transform: translateX(5px); }
            75% { transform: translateX(-5px); }
        }
        .animate-shake {
            animation: shake 0.4s ease-in-out;
        }
    </style>
</head>
<body class="min-h-screen bg-slate-100 flex flex-col items-center p-2 md:p-4">

    <div id="exportCard" class="bg-white">
        <div class="-mx-[40px] -mt-[40px] mb-6 overflow-hidden">
            <img src="https://i.ibb.co/spV8WxDx/bg.jpg" alt="Header Rei do Box" class="w-full h-auto" referrerPolicy="no-referrer">
        </div>

        <div class="space-y-3">
            <div class="text-center border-b border-slate-100 pb-3">
                <p class="font-black text-slate-900 text-lg uppercase">CLIENTE: <span id="expCliente"></span></p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-b border-slate-100 pb-3 text-center">
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-black uppercase">Modelo</p>
                    <p id="expModelo" class="font-bold text-red-600"></p>
                </div>
                <div id="expContainerAluminio" class="space-y-1">
                    <p class="text-[10px] font-bold text-black uppercase">Alumínio</p>
                    <p id="expAluminio" class="font-bold text-red-600"></p>
                </div>
                <div id="expContainerMedidas" class="space-y-1">
                    <p class="text-[10px] font-bold text-black uppercase">Medidas</p>
                    <p id="expMedidas" class="font-bold text-red-600"></p>
                </div>
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-black uppercase">Data</p>
                    <p id="expData" class="font-bold text-red-600"></p>
                </div>
            </div>

            <div class="bg-red-600 p-4 rounded-xl flex items-center justify-center border border-red-700 shadow-md">
                <span id="expValorTotal" class="text-2xl font-black text-white uppercase tracking-tight"></span>
            </div>

            <div id="expContainerObservacao" class="hidden bg-slate-50 p-3 rounded-xl border border-slate-100">
                <p class="text-[10px] font-bold text-black uppercase mb-1">Observação</p>
                <p id="expObservacao" class="text-xs font-bold text-black uppercase"></p>
            </div>

            <div id="expContainerParcelamento" class="space-y-3">
                <p class="text-xs font-black text-black uppercase text-center mb-2">💳 OPÇÕES DE PARCELAMENTO - CARTÃO DE CRÉDITO</p>
                <div id="expTabela" class="grid grid-cols-1 gap-1.5"></div>
            </div>

            <div class="pt-6 border-t border-slate-100 grid grid-cols-2 gap-3 text-[9px] font-bold text-black uppercase">
                <div class="flex items-center justify-center gap-2">
                    <span class="text-red-600 text-base">🛠️</span> Instalação Inclusa
                </div>
                <div class="flex items-center justify-center gap-2">
                    <span class="text-red-600 text-base">💎</span> 12 Meses Garantia
                </div>
                <div class="flex items-center justify-center gap-2">
                    <span class="text-red-600 text-base">🚚</span> Pagamento na Entrega
                </div>
                <div class="flex items-center justify-center gap-2">
                    <span class="text-red-600 text-base">🕐</span> Validade: 5 Dias
                </div>
            </div>
            <div class="pt-3 text-center border-t border-slate-50">
                <p class="text-xs font-black text-red-600 tracking-widest">WWW.REIDOBOX.COM</p>
            </div>
            <div class="pt-3">
                <!-- Espaço vazio -->
            </div>
        </div>
    </div>

    <div class="w-full max-w-7xl flex flex-col lg:flex-row gap-4 items-start justify-center">
        <!-- Coluna de Inputs -->
        <div class="w-full lg:w-[350px] bg-white rounded-2xl shadow-sm border border-slate-200 p-3 lg:sticky lg:top-8 z-10">
            <div class="flex justify-between items-center mb-1.5">
                <label class="block font-padrao font-bold text-black flex items-center gap-2">
                    <span class="bg-amber-50 text-amber-600 p-1 rounded-lg">🏷️</span>
                    ORÇAMENTOS RÁPIDO
                </label>
                <div class="flex items-center gap-2">
                    <button id="btnNotificacao" onclick="mostrarNotificacoes()" class="relative p-2 rounded-xl hover:bg-red-50 transition-all text-black hidden border-2 border-transparent" title="Notificações de Retorno">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                        </svg>
                        <span id="badgeNotificacao" class="absolute -top-1 -right-1 block h-3 w-3 rounded-full bg-red-600 ring-2 ring-white animate-ping"></span>
                    </button>
                </div>
            </div>

            <button onclick="novoOrcamento()" class="w-full bg-pink-500 text-white font-bold font-padrao py-3 rounded-2xl hover:bg-pink-600 active:scale-[0.98] flex items-center justify-center gap-3 transition-all shadow-lg shadow-pink-100 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Novo Orçamento
            </button>
            
            <div class="space-y-2">
                <div>
                    <span class="text-[10px] font-bold text-black uppercase tracking-wider">Nome do Cliente</span>
                    <input type="text" id="nomeCliente" placeholder="Digite o nome do cliente" oninput="mascaraNome(this)" onfocus="selecionarTudo(this)"
                        class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-padrao transition-all">
                </div>

                <div>
                    <span class="text-[10px] font-bold text-black uppercase tracking-wider">Canal:</span>
                    <select id="origemCliente" class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-padrao transition-all">
                        <option value="Meta Ads">Meta Ads</option>
                        <option value="Google Ads (Site)">Google Ads (Site)</option>
                        <option value="Indicação">Indicação</option>
                        <option value="Instagram">Instagram</option>
                        <option value="Facebook">Facebook</option>
                    </select>
                </div>

                <div>
                    <span class="text-[10px] font-bold text-black uppercase tracking-wider">Tipo de serviço</span>
                    <select id="tipoBox" onchange="toggleLargura2(true)" class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-padrao transition-all">
                        <option value="Box Frontal Padrão">Box Frontal Padrão</option>
                        <option value="Box de Canto (Tipo L)">Box de Canto (Tipo L)</option>
                        <option value="Box Sob Medida">Box Sob Medida</option>
                        <option value="Manutenção em Box">Manutenção em Box</option>
                        <option value="Espelho Prata">Espelho Prata</option>
                    </select>
                </div>

                <div id="containerTipoVidro">
                    <span class="text-[10px] font-bold text-black uppercase tracking-wider">Tipo de Vidro</span>
                    <select id="tipoVidro" onchange="calcularTudo()" class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-padrao transition-all">
                        <option value="Incolor 8mm">Incolor 8mm</option>
                        <option value="Fumê 8mm">Fumê 8mm</option>
                    </select>
                </div>

                <div id="containerAcabamento">
                    <span class="text-[10px] font-bold text-black uppercase tracking-wider">Alumínio</span>
                    <select id="acabamento" onchange="calcularTudo()" class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-padrao transition-all">
                        <option value="Preto">Preto</option>
                        <option value="Branco">Branco</option>
                        <option value="Prata">Prata</option>
                    </select>
                </div>

                <div id="containerMedidas" class="grid grid-cols-2 gap-3">
                    <div>
                        <span class="text-[10px] font-bold text-black uppercase tracking-wider">Altura (m)</span>
                        <input type="text" id="altura" value="1.90" placeholder="1.90" inputmode="decimal" oninput="mascaraMedida(this)" onfocus="selecionarTudo(this)"
                            class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-numeric transition-all">
                    </div>
                    <div>
                        <span class="text-[10px] font-bold text-black uppercase tracking-wider">Largura 1 (m)</span>
                        <input type="text" id="largura" value="0.00" placeholder="0.00" inputmode="decimal" oninput="mascaraMedida(this)" onfocus="selecionarTudo(this)"
                            class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-numeric transition-all">
                    </div>
                </div>

                <div id="campoLargura2" class="hidden">
                    <span class="text-[10px] font-bold text-black uppercase tracking-wider">Largura 2 (m)</span>
                    <input type="text" id="largura2" value="0.00" placeholder="0.00" inputmode="decimal" oninput="mascaraMedida(this)" onfocus="selecionarTudo(this)"
                        class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-numeric transition-all">
                </div>

                <div id="containerValorM2">
                    <span class="text-[10px] font-bold text-black uppercase tracking-wider">Valor do m² (R$)</span>
                    <input type="text" id="valorM2" value="R$ 450,00" placeholder="R$ 450,00" inputmode="numeric" 
                        oninput="mascaraMoeda(this)"
                        onkeydown="checkMoedaPrefix(event)" 
                        onclick="fixMoedaCursor(this)"
                        onselect="fixMoedaCursor(this)"
                        onfocus="selecionarTudo(this)"
                        class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-numeric font-bold transition-all">
                </div>

                <div id="campoValorManutencao" class="hidden">
                    <span class="text-[10px] font-bold text-black uppercase tracking-wider">Valor do Serviço (R$)</span>
                    <input type="text" id="valorManutencao" placeholder="R$ 0,00" inputmode="numeric" 
                        oninput="mascaraMoeda(this)"
                        onkeydown="checkMoedaPrefix(event)" 
                        onclick="fixMoedaCursor(this)"
                        onselect="fixMoedaCursor(this)"
                        onfocus="selecionarTudo(this)"
                        class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-numeric font-bold transition-all">
                </div>

                <div id="campoObservacao" class="hidden">
                    <span class="text-[10px] font-bold text-black uppercase tracking-wider">Observação</span>
                    <textarea id="observacao" placeholder="Texto complementar..." oninput="mascaraMaiuscula(this); calcularTudo()" onfocus="selecionarTudo(this)"
                        class="w-full bg-slate-50 border border-slate-200 rounded-xl py-1.5 px-3 outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 font-padrao transition-all h-16 resize-none"></textarea>
                </div>

                <div class="pt-2 border-t border-slate-100 space-y-1">
                    <div id="containerAreaTotal" class="flex justify-between items-center bg-slate-50 p-2 rounded-xl">
                        <span class="text-[10px] font-bold text-black uppercase">Área Total</span>
                        <span id="areaTotalCalculada" class="font-numeric font-bold text-black">0.00 m²</span>
                    </div>
                    <div class="flex justify-between items-center p-1">
                        <span class="font-padrao font-bold text-black">Total à Vista:</span>
                        <span id="valorFinalCalculado" class="text-2xl font-black text-black">R$ 0,00</span>
                    </div>
                </div>

                <button id="btnSalvarOrcamento" onclick="salvarOrcamento(); copiarWhatsApp()" class="w-full bg-amber-600 text-white font-bold font-padrao py-3 rounded-2xl hover:bg-amber-700 active:scale-[0.98] flex items-center justify-center gap-3 transition-all shadow-lg shadow-amber-100 mb-4">
                    <div id="btnSalvarContent" class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                        </svg>
                        Preparar Orçamento
                    </div>
                </button>

                <button onclick="compartilharWhatsAppDireto()" class="w-full bg-green-600 text-white font-bold font-padrao py-3 rounded-2xl hover:bg-green-700 active:scale-[0.98] flex items-center justify-center gap-3 transition-all shadow-lg shadow-green-100 mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.313 1.592 5.448 0 9.886-4.438 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
                    </svg>
                    Compartilhar no Whatsapp
                </button>

                <button onclick="exportarImagem()" class="w-full bg-blue-600 text-white font-bold font-padrao py-3 rounded-2xl hover:bg-blue-700 active:scale-[0.98] flex items-center justify-center gap-3 transition-all shadow-lg shadow-blue-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    Gerar imagem
                </button>

                <button id="btnCalculadora" onclick="abrirCalculadora()" class="w-full bg-slate-800 text-white font-bold font-padrao py-3 rounded-2xl hover:bg-black active:scale-[0.98] flex items-center justify-center gap-3 transition-all shadow-lg shadow-slate-200 mt-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    Calculadora Rápida
                </button>

            </div>
        </div>

        <!-- Coluna Central: Abas -->
        <div class="w-full lg:flex-1 space-y-4">
            <!-- Navegação de Abas -->
            <div class="grid grid-cols-2 sm:flex bg-white p-1 rounded-2xl shadow-sm border border-slate-200 gap-1 sm:gap-0 overflow-x-auto no-scrollbar">
                <button onclick="switchTab('orcamento')" id="tabOrcamento" class="flex-1 py-2.5 rounded-xl font-bold text-[10px] sm:text-sm transition-all tab-active uppercase whitespace-nowrap px-4">
                    ORÇAMENTO
                </button>
                <button onclick="switchTab('lucro')" id="tabLucro" class="flex-1 py-2.5 rounded-xl font-bold text-[10px] sm:text-sm transition-all tab-inactive uppercase whitespace-nowrap px-4">
                    LUCRO LÍQUIDO
                </button>
                <button onclick="switchTab('historico')" id="tabHistorico" class="flex-1 py-2.5 rounded-xl font-bold text-[10px] sm:text-sm transition-all tab-inactive uppercase whitespace-nowrap px-4">
                    GERENCIAR VENDAS
                </button>
                <button onclick="switchTab('notificacoes')" id="tabNotificacoes" class="flex-1 py-2.5 rounded-xl font-bold text-[10px] sm:text-sm transition-all tab-inactive uppercase whitespace-nowrap px-4">
                    NOTIFICAÇÕES
                </button>
                <button onclick="switchTab('contas')" id="tabContas" class="flex-1 py-2.5 rounded-xl font-bold text-[10px] sm:text-sm transition-all tab-inactive uppercase whitespace-nowrap px-4">
                    MINHAS CONTAS
                </button>
            </div>

            <!-- Conteúdo Aba Orçamento -->
            <div id="contentOrcamento" class="space-y-4">
                <div id="containerTabela" class="hidden space-y-2">
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden max-lg:hidden">
                        <div class="px-4 py-2 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                            <h2 class="font-bold text-slate-700 flex items-center gap-2">
                                <span class="bg-amber-100 text-amber-700 p-1 rounded-md text-xs">💳</span>
                                OPÇÕES DE PARCELAMENTO
                            </h2>
                            <div class="flex items-center gap-4">
                                <label class="flex items-center gap-2 cursor-pointer group">
                                    <input type="checkbox" id="semParcelamento" onchange="calcularTudo()" class="w-4 h-4 text-amber-600 border-slate-300 rounded focus:ring-amber-500 transition-all">
                                    <span class="text-[10px] font-bold text-slate-600 uppercase group-hover:text-amber-600 transition-colors">Proposta sem parcelamento</span>
                                </label>
                                <span class="text-[10px] font-bold text-black uppercase">Taxas inclusas</span>
                            </div>
                        </div>
                        <div id="corpoTabela" class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-slate-200"></div>
                    </div>
                    
                    <div class="hidden">
