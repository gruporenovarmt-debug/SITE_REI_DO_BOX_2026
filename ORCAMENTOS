                        <input type="checkbox" ${alertar ? 'checked' : ''} class="w-3.5 h-3.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                    </div>
                    ` : '<div class="ml-auto"></div>'}
                    <div class="flex items-center gap-1">
                        <button onclick="toggleStatusConta(this)" class="status-badge px-2 py-0.5 rounded-full text-[9px] font-black uppercase tracking-widest transition-all border ${statusInfo.color}">
