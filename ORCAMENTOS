                        <input type="text" value="${nome}" placeholder="NOME DA CONTA" onfocus="selecionarTudo(this)" onclick="ativarEdicaoConta(this)" oninput="mascaraMaiuscula(this); this.closest('.conta-row').querySelector('.initial-circle').innerText = this.value.charAt(0).toUpperCase() || (this.closest('.conta-row').dataset.tipo === 'fixa' ? 'F' : 'V')"
