{
  "entities": {
    "Orcamento": {
      "title": "Orçamento",
      "description": "Dados de orçamentos e arquivos associados",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clienteNome": { "type": "string" },
        "clienteEmail": { "type": "string" },
        "linkArquivo": { "type": "string", "description": "URL ou Base64 do arquivo" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pendente", "concluido"] }
      },
      "required": ["clienteNome", "linkArquivo", "createdAt"]
    }
  },
  "firestore": {
    "orcamentos": {
      "schema": "Orcamento",
      "description": "Lista de orçamentos recebidos"
    }
  }
}
